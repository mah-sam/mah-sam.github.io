---
import { SITE } from '../lib/utils';
---

<section class="relative min-h-screen flex items-center overflow-hidden dot-grid">
  <!-- Animated gradient orbs -->
  <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-2" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-5 py-20 sm:py-32 relative z-10">
    <div class="max-w-2xl">
      <!-- Greeting -->
      <p class="text-[var(--color-text-muted)] text-xs sm:text-sm font-mono mb-3 sm:mb-4 scroll-reveal">
        Hello, I'm
      </p>

      <!-- Name -->
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-3 sm:mb-4 scroll-reveal">
        Mahmoud Sameh
      </h1>

      <!-- Title -->
      <p class="text-lg sm:text-2xl md:text-3xl font-mono gradient-text font-medium mb-4 sm:mb-6 scroll-reveal">
        AI Researcher & Engineer
      </p>

      <!-- Tagline -->
      <p class="text-sm sm:text-lg text-[var(--color-text-secondary)] max-w-xl mb-8 sm:mb-10 scroll-reveal leading-relaxed">
        Electrical engineer with a deep focus on AI. I research, build, and ship. My work spans
        computer vision, foundation model adaptation, and applied ML across domains from fintech
        and healthcare to robotics and hyperspectral imaging.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 scroll-reveal">
        <a
          href="https://raw.githubusercontent.com/mah-sam/my_cv/refs/heads/main/Mahmoud_Sameh_CV.pdf"
          target="_blank"
          class="inline-flex items-center gap-2 px-5 py-2.5 sm:px-6 sm:py-3 rounded-lg bg-[var(--color-accent-blue)] text-white font-medium text-sm hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          View CV
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 sm:px-6 sm:py-3 rounded-lg border border-[var(--color-border)] text-[var(--color-text-primary)] font-medium text-sm hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-card)] transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-muted)]"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
  </div>
</section>
