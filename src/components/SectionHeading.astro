---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8 sm:mb-12">
  <h2 class="text-xl sm:text-2xl md:text-3xl font-bold mb-1.5 sm:mb-2">{title}</h2>
  {subtitle && (
    <p class="text-sm sm:text-base text-[var(--color-text-secondary)]">{subtitle}</p>
  )}
  <div class="w-12 sm:w-16 h-0.5 bg-gradient-to-r from-[var(--color-accent-blue)] to-[var(--color-accent-violet)] mt-3 sm:mt-4 rounded-full"></div>
</div>
