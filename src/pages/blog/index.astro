---
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="Blog" description="Thoughts on AI, engineering, and the occasional reflection.">
  <section class="pt-24 sm:pt-32 pb-12 sm:pb-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="scroll-reveal">
        <SectionHeading
          title="Blog"
          subtitle="Thoughts on AI, engineering, and the occasional reflection."
        />
      </div>

      {posts.length > 0 ? (
        <div class="space-y-4 sm:space-y-6">
          {posts.map((post) => (
            <div class="scroll-reveal">
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.id}
                tags={post.data.tags}
                body={post.body || ''}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 sm:py-20">
          <p class="text-[var(--color-text-muted)] font-mono text-xs sm:text-sm">
            No posts yet. Check back soon.
          </p>
        </div>
      )}
    </div>
  </section>
</PageLayout>
