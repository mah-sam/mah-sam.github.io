---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Timeline from '../components/Timeline.astro';
import type { TimelineEntry } from '../components/Timeline.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

let featuredPubs: any[] = [];
try {
  const allPubs = await getCollection('publications');
  featuredPubs = allPubs
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 3);
} catch {
  // No publications yet
}

const careerTimeline: TimelineEntry[] = [
  {
    date: 'Mar 2026 – Present',
    title: 'Independent AI Researcher & Consultant',
    company: 'Shannah App · Independent',
    description: 'Conducting independent AI research and consulting for select projects. Advising Shannah, a pre-launch application currently under development, on its AI architecture and capabilities.',
    accent: 'violet',
  },
  {
    date: 'Oct 2025 – Feb 2026',
    title: 'AI Engineer Intern',
    company: 'Aajil Fintech',
    description: 'Built AI infrastructure to automate credit risk assessment. Developed a feature-engineering pipeline generating financial analyses from raw application data. Trained and deployed classification/extraction models with end-to-end MLOps.',
    accent: 'blue',
  },
  {
    date: 'Jun – Aug 2025',
    title: 'Research Assistant',
    company: 'King Fahd University of Petroleum and Minerals',
    description: 'Designed a complete experimental protocol for a novel hyperspectral imaging dataset of date fruits. Developed the full software stack for push-broom HSI hardware and created an open-source GUI (PyQt6) now under journal review at SoftwareX.',
    accent: 'violet',
  },
  {
    date: '2021 – 2025',
    title: 'B.S. Electrical Engineering',
    company: 'Islamic University of Madinah',
    description: 'Chose EE for its balance of hardware, software, and AI. Graduated top of class (4.95/5). Complemented formal education with Harvard\'s CS50 and self-driven courses in Python, C, and AI. Led and developed numerous projects across computer vision, robotics, and applied ML. Led technical aspects of multiple research papers as first or second author, won Enjaz Hackathon, earned 2nd Best Graduation Project in AI, and passed KAUST Academy\'s AI stages.',
    accent: 'blue',
  },
  {
    date: '2020 – 2021',
    title: 'Preparatory Year',
    company: 'Islamic University of Madinah',
    description: 'Passed with a perfect 5/5 GPA without much effort, thanks to the self-study foundation built during the gap year (Thank you Khan Academy). Used the abundant free time to go deeper into calculus, linear algebra, and coding through online courses.',
    accent: 'violet',
  },
  {
    date: '2019 – 2020',
    title: 'The Gap Year',
    company: 'Self-Directed',
    description: 'Took a deliberate year off to relearn mathematics the right way, revitalizing a love that high school methods had nearly killed. If you hate math, you\'re learning it wrong. Dove into JavaScript, computer science fundamentals, and psychology. Khan Academy was the star of that year: 1.9 million energy points earned through relentless dedication. A year where my love for coding and computers grew rapidly.',
    accent: 'violet',
  },
  {
    date: '2019',
    title: 'High School Graduate',
    company: 'Top 5 in Class',
    description: 'Graduated as one of the top 5 students. Left with a determination to learn differently, setting the stage for everything that followed.',
    accent: 'blue',
  },
];
---

<PageLayout>
  <Hero />

  <!-- Featured Projects -->
  <section class="py-12 sm:py-20 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="scroll-reveal">
        <SectionHeading
          title="Featured Projects"
          subtitle="Selected work showcasing my engineering and problem-solving approach."
        />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {featuredProjects.map((project) => (
          <div class="scroll-reveal">
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              image={project.data.image}
              github={project.data.github}
              live={project.data.live}
              link={project.data.link}
              linkLabel={project.data.linkLabel}
            />
          </div>
        ))}
      </div>
      <div class="mt-6 sm:mt-8 text-right scroll-reveal">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-xs sm:text-sm font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-accent-blue)] transition-colors"
        >
          View all projects
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Publications -->
  <section class="py-12 sm:py-20 px-4 sm:px-6 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto">
      <div class="scroll-reveal">
        <SectionHeading
          title="Publications"
          subtitle="Research and academic contributions to the AI field."
        />
      </div>

      {featuredPubs.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {featuredPubs.map((pub) => (
            <div class="scroll-reveal">
              <PublicationCard
                title={pub.data.title}
                authors={pub.data.authors}
                venue={pub.data.venue}
                date={pub.data.date}
                doi={pub.data.doi}
                pdf={pub.data.pdf}
                abstract={pub.data.abstract}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="scroll-reveal">
          <div class="glass-card p-5 sm:p-8 flex items-start sm:items-center gap-4 sm:gap-6 max-w-2xl">
            <div class="shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-lg bg-[var(--color-accent-violet-dim)] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-violet)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <p class="font-medium text-sm sm:text-base mb-1">Research in progress</p>
              <p class="text-xs sm:text-sm text-[var(--color-text-secondary)]">
                Publications will appear here as they are released. Currently working on AI applications research.
              </p>
            </div>
          </div>
        </div>
      )}

      {featuredPubs.length > 0 && (
        <div class="mt-6 sm:mt-8 text-right scroll-reveal">
          <a
            href="/publications"
            class="inline-flex items-center gap-2 text-xs sm:text-sm font-mono text-[var(--color-text-secondary)] hover:text-[var(--color-accent-blue)] transition-colors"
          >
            View all publications
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Career Timeline -->
  <section class="py-12 sm:py-20 px-4 sm:px-6 border-t border-[var(--color-border)] relative overflow-hidden">
    <!-- Background accent -->
    <div class="hero-orb hero-orb-1 hidden sm:block" style="top: 50%; right: -250px; opacity: 0.5;" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2 hidden sm:block" style="top: 20%; left: -200px; opacity: 0.4;" aria-hidden="true"></div>

    <div class="max-w-5xl mx-auto relative z-10">
      <div class="scroll-reveal">
        <SectionHeading
          title="Career Journey"
          subtitle="From foundations to AI, a timeline of growth."
        />
      </div>
      <Timeline entries={careerTimeline} />
    </div>
  </section>
</PageLayout>
