---
import PageLayout from '../layouts/PageLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

let publications: any[] = [];
try {
  const allPublications = await getCollection('publications');
  publications = allPublications.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
} catch {
  // No publications yet
}
---

<PageLayout title="Publications" description="Academic publications and research work.">
  <section class="pt-24 sm:pt-32 pb-12 sm:pb-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="scroll-reveal">
        <SectionHeading
          title="Publications"
          subtitle="Academic publications and research work."
        />
      </div>

      {publications.length > 0 ? (
        <div class="space-y-4 sm:space-y-6">
          {publications.map((pub) => (
            <div class="scroll-reveal">
              <PublicationCard
                title={pub.data.title}
                authors={pub.data.authors}
                venue={pub.data.venue}
                date={pub.data.date}
                doi={pub.data.doi}
                pdf={pub.data.pdf}
                abstract={pub.data.abstract}
                tags={pub.data.tags}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 sm:py-20">
          <div class="glass-card inline-block p-5 sm:p-8">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 sm:mb-4 text-[var(--color-text-muted)]"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            <p class="text-[var(--color-text-muted)] font-mono text-xs sm:text-sm">
              Publications coming soon.
            </p>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
